import streamlit as st

# =========================================================
# 1. CONFIGURACIÓN DE LA PÁGINA (Debe ser la primera orden)
# =========================================================
st.set_page_config(
    page_title="MIS - Dashboard Overview",
    page_icon="📊",
    layout="wide",                # Usa todo el ancho de la pantalla
    initial_sidebar_state="expanded"
)

# =========================================================
# 2. BARRA LATERAL IZQUIERDA (SIDEBAR)
# =========================================================
with st.sidebar:
    # Perfil de usuario sutil
    st.markdown("### 👤 Hello! \n **Jordy Cartagena**")
    st.caption("Biblioteca General - Administración")
    st.write("---")
    
    # Navegación del Dashboard
    st.markdown("### 📱 DASHBOARD")
    menu_dashboard = st.radio(
        label="Selecciona una vista:",
        options=["Overview", "Préstamos", "Análisis"],
        label_visibility="collapsed" # Esconde el título del radio button
    )
    
    st.write("---")
    
    st.markdown("### 📚 LIBRERÍA")
    menu_libreria = st.radio(
        label="Gestión:",
        options=["Catálogo", "Disponibilidad", "Settings"],
        label_visibility="collapsed"
    )

# =========================================================
# 3. CONTENIDO PRINCIPAL (Dependiendo de la selección)
# =========================================================
if menu_dashboard == "Overview":
    
    # Encabezado principal
    st.title("Dashboard Overview")
    st.markdown("<p style='color: #666666; font-size: 1.1rem; margin-top:-15px;'>Here's your financial overview for today.</p>", unsafe_allow_html=True)
    st.write("")

    # Fila de Tarjetas KPI (Métricas principales)
    # Usamos columnas de Streamlit para la distribución horizontal
    kpi1, kpi2, kpi3 = st.columns(3)
    
    with kpi1:
        st.metric(label="Préstamos Registrados", value="2,956", delta="12 meses", delta_color="off")
        
    with kpi2:
        st.metric(label="Tasa de Devolución", value="85%", delta="Total earnings received", delta_color="off")
        
    with kpi3:
        st.metric(label="Tasa de Vencimiento", value="15%", delta="Total spending across", delta_color="off")

    st.write("---")

    # Fila de Gráficos (Visualizaciones / Tableau)
    chart_col1, chart_col2 = st.columns([2, 1]) # 2/3 de ancho para el primero, 1/3 para el segundo
    
    with chart_col1:
        st.subheader("Spending Overview")
        # Aquí irá el contenedor para incrustar el primer gráfico de Tableau
        st.info("Espacio reservado para el gráfico de pastel de Tableau (Matemática, Programación, etc.)")
        
    with chart_col2:
        st.subheader("Top 5 Libros")
        # Aquí irá el contenedor para el segundo gráfico de Tableau
        st.info("Espacio reservado para el gráfico de barras de Tableau")

elif menu_dashboard == "Préstamos":
    st.title("Administración de Préstamos")
    st.write("Contenido de la sección de préstamos en desarrollo...")
