def kpi_1(df): #se debe cargar el dataframe de los libros
    #Esta funcion buscara determinar si el umbral del 12% (0.12) ha sido superado, para ello, se listan las siguientes variables: 
    umb = 0.12
    top = 10 #visualizacion de la tabla (de manera temporal para este taller) 

    arrear = df["dias_vencido"] > 0 #se filtran a los morosos

    overview = (df.groupby["id_libro", "titulo", "categoria"]).agg( #se crea un dataframe extrayendo las columnas de interes (libros prestados)
        total_loans = ("id_prestamo", "count"), #se agrega una fila de prestamos totales
        overdued = ("dias_vencido", lambda x: (x > 0).sum()) # se agrega otra fila de prestamos morosos, usando una funcion temporal
    ).reset_index().sort_values("total_loans", ascending=False).head(top) #se resetean los indices, ordena y muestra en el orden de 10. 

